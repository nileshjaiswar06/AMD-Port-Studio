<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AMD Port Studio — {{ repo_name }}</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; line-height: 1.5; }
    h1 { color: #ed1c24; margin-bottom: 0.25rem; }
    h2 { margin-top: 2rem; border-bottom: 1px solid #ddd; padding-bottom: 0.25rem; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.05em; color: #555; }
    a { color: #ed1c24; }
    .meta { color: #666; font-size: 0.9rem; }
    .score { font-size: 2.5rem; font-weight: bold; color: #ed1c24; }
    .tier { display: inline-block; background: #fef3c7; color: #92400e; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.85rem; margin-left: 0.5rem; }
    .summary { background: #f9fafb; border-left: 4px solid #ed1c24; padding: 1rem; margin: 1rem 0; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
    th, td { border: 1px solid #e5e7eb; padding: 0.5rem 0.75rem; text-align: left; }
    th { background: #f3f4f6; }
    .status-supported { color: #059669; font-weight: 600; }
    .status-partial { color: #d97706; font-weight: 600; }
    .status-unsupported { color: #dc2626; font-weight: 600; }
    .status-unknown { color: #6b7280; font-weight: 600; }
    ol, ul { padding-left: 1.25rem; }
    li { margin: 0.35rem 0; }
    pre { background: #111; color: #e5e7eb; padding: 1rem; overflow-x: auto; font-size: 0.8rem; border-radius: 6px; }
    .footer { margin-top: 3rem; font-size: 0.8rem; color: #9ca3af; text-align: center; }
    .badge { font-size: 0.75rem; background: #dbeafe; color: #1e40af; padding: 0.15rem 0.5rem; border-radius: 4px; }
  </style>
</head>
<body>
  <h1>{{ repo_name }}</h1>
  <p class="meta"><a href="{{ repo_url }}">{{ repo_url }}</a></p>
  {% if ai_used %}<p><span class="badge">AI narrative included</span></p>{% endif %}

  <h2>Compatibility</h2>
  <p>
    <span class="score">{{ analysis.compatibilityScore }}%</span>
    <span class="tier">{{ findings.compatibility.tier }}</span>
  </p>
  <p class="meta">
    Difficulty: {{ analysis.migrationDifficulty }} ·
    Risk: {{ analysis.riskLevel }} ·
    Estimated: {{ analysis.estimatedHours }} hours
  </p>

  <h2>Summary</h2>
  <div class="summary">{{ analysis.summary }}</div>

  <h2>Migration steps</h2>
  <ol>
    {% for step in analysis.migrationSteps %}
    <li>{{ step }}</li>
    {% endfor %}
  </ol>

  {% if analysis.recommendedAlternatives %}
  <h2>Recommended alternatives</h2>
  <ul>
    {% for alt in analysis.recommendedAlternatives %}
    <li>{{ alt }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  <h2>ROCm compatibility components</h2>
  <table>
    <thead>
      <tr>
        <th>Component</th>
        <th>Status</th>
        <th>Alternative</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {% for c in findings.compatibility.components %}
      <tr>
        <td>{{ c.name or c.label or c.id }}</td>
        <td class="status-{{ c.status }}">{{ c.status }}</td>
        <td>{{ c.alternative or "—" }}</td>
        <td>{{ c.notes or "—" }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>Generated ROCm Dockerfile</h2>
  <pre>{{ dockerfile }}</pre>

  <h2>Deploy guide</h2>
  <ol>
    {% for step in deploy_steps %}
    <li>{{ step }}</li>
    {% endfor %}
  </ol>

  <p class="footer">Generated by AMD Port Studio · ROCm migration report</p>
</body>
</html>
